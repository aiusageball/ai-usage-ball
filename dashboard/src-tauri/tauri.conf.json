{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AI Usage Ball",
  "version": "0.2.0",
  "identifier": "com.aiusageball.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AI Usage Ball",
        "width": 860,
        "height": 470,
        "minWidth": 800,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "center": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:8000 https://api.lemonsqueezy.com; media-src 'self' http://127.0.0.1:8000; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "createUpdaterArtifacts": true,
    "resources": {
      "resources/aipulse-server/": "backend/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": "Developer ID Application: BIN XU (46C3XZQNFT)",
      "entitlements": "entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/aiusageball/ai-usage-ball/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJBQTE1MDA3QUNDQ0NBMkUKUldRdXlzeXNCMUNodWo2M0pHUzBESmsvcGY1MTVKVlU1VEJsbGhkWnVMSk5iVzhYd0VReVVuOHEK"
    }
  }
}
