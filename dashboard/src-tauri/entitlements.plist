<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- The bundled backend is a PyInstaller binary with an embedded Python
         runtime whose libraries are signed under a different Team ID. Without
         disabling library validation, macOS refuses to load them ("different
         Team IDs") and the backend crashes on launch. Python/Electron-style
         apps commonly need these; notarization still passes. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
</dict>
</plist>
